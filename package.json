{
  "name": "parallel",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm test:scripts && pnpm -r test && cargo test",
    "test:scripts": "vitest run scripts/*.test.mjs",
    "smoke:bridge": "cargo build -p parallel-projectctl && node scripts/bridge-smoke.mjs --projectctl target/debug/projectctl",
    "dev:desktop": "pnpm --filter @parallel/desktop tauri dev",
    "build:desktop": "pnpm --filter @parallel/desktop tauri build"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
