{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "parallel",
  "version": "0.1.0",
  "identifier": "ai.light.projectworkflowos",
  "build": {
    "beforeDevCommand": "cargo build -p parallel-projectctl --bin projectctl && pnpm dev",
    "beforeBuildCommand": "cargo build -p parallel-projectctl --bin projectctl --release && pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "parallel",
        "width": 720,
        "height": 560,
        "minWidth": 520,
        "minHeight": 420,
        "visible": false
      },
      {
        "label": "menubar",
        "title": "parallel",
        "url": "/?surface=menubar",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 420,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/projectctl"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
